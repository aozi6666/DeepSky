        <UserObject label="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;useEffect&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(() &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;config&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;AgentConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Create&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;()&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetRTC&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;APP_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;ROOM_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;TOKEN&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetServer&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;SERVER_URL&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;AUTH_TOKEN&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetUser&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`用户_&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;split&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;_&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;)[&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;1&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetAssistant&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;assistant_001&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;AI 助手&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// 已关闭：记忆功能会导致 LLM 回复混入其它对话/旧上下文，回复错乱；待后端或使用方式理清后再开启&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// .EnableMemory(&quot;wallpaper_new_memory&quot;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetWelcomeMessage&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;你好&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetLLM&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Mode&quot;: &quot;ArkV3&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;EndPointId&quot;: &quot;ep-20251223145959-tdvd5&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;SystemMessages&quot;: [&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你是一个友好、专业的 AI 助手。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你会用简洁、清晰的语言回答用户的问题。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;对于记忆部分，只在用户询问时才根据记忆回复。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你需要在你的回复末尾加入json表示的表情和动作，例如{&#39;emotion&#39;: &#39;happy&#39;,&#39;action&#39;: &#39;nod&#39;}&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;当用户希望你修改你的名字/称呼时，请调用 set_assistant_profile 工具。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;当用户发送图片时，你需要仔细分析图片内容并回答用户的问题。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;【nanobot 路由规则 - 文档/文件交付 &amp;amp; Skills】最终结果会稍后自动出现在对话中；你无需再额外解释或重复调用工具。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;【nanobot 与简单问候】若用户只是发送简单问候（如「你好」「在吗」），请正常回复问候，不要提及正在处理任务。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ],&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;VisionConfig&quot;: { &quot;Enable&quot;: true },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ThinkingType&quot;: &quot;disabled&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Prefill&quot;: true,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;HistoryLength&quot;: 10&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetASR&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Provider&quot;: &quot;volcano&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ProviderParams&quot;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Mode&quot;: &quot;bigmodel&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;AppId&quot;: &quot;9934702733&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;AccessToken&quot;: &quot;WIG86BTrlHUsfx5pZefYgkGXCwtb44mV&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ApiResourceId&quot;: &quot;volc.bigasr.sauc.duration&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetTTS&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Provider&quot;: &quot;volcano_bidirection&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ProviderParams&quot;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;app&quot;: { &quot;appid&quot;: &quot;9934702733&quot;, &quot;token&quot;: &quot;WIG86BTrlHUsfx5pZefYgkGXCwtb44mV&quot; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;audio&quot;: { &quot;voice_type&quot;: &quot;zh_male_wennuanahu_moon_bigtts&quot; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ResourceId&quot;: &quot;volc.service_type.10029&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;IgnoreBracketText&quot;: [1,2,3,4,5]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetExtraConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;InterruptMode&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;0&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableSubtitle&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableConversationStateCallback&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(true)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableDebug&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(true);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" link="&lt;div style=&quot;color: #e4e4e4;background-color: #181818;font-family: Consolas, &#39;Courier New&#39;, monospace;font-weight: normal;font-size: 14px;line-height: 19px;white-space: pre;&quot;&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;useEffect&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(() &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;=&amp;gt;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;const&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;config&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;=&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt; &lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;AgentConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;Create&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;()&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetRTC&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;APP_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;ROOM_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;TOKEN&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetServer&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;SERVER_URL&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;AUTH_TOKEN&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetUser&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`用户_&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;${&lt;/span&gt;&lt;span style=&quot;color: #aaa0fa;&quot;&gt;USER_ID&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;.&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;split&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&#39;_&#39;&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;)[&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;1&lt;/span&gt;&lt;span style=&quot;color: #d6d6dd;&quot;&gt;]&lt;/span&gt;&lt;span style=&quot;color: #82d2ce;&quot;&gt;}&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetAssistant&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;assistant_001&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;AI 助手&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// 已关闭：记忆功能会导致 LLM 回复混入其它对话/旧上下文，回复错乱；待后端或使用方式理清后再开启&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;font-style: italic;&quot;&gt;// .EnableMemory(&quot;wallpaper_new_memory&quot;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetWelcomeMessage&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;你好&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetLLM&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Mode&quot;: &quot;ArkV3&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;EndPointId&quot;: &quot;ep-20251223145959-tdvd5&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;SystemMessages&quot;: [&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你是一个友好、专业的 AI 助手。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你会用简洁、清晰的语言回答用户的问题。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;对于记忆部分，只在用户询问时才根据记忆回复。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;你需要在你的回复末尾加入json表示的表情和动作，例如{&#39;emotion&#39;: &#39;happy&#39;,&#39;action&#39;: &#39;nod&#39;}&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;当用户希望你修改你的名字/称呼时，请调用 set_assistant_profile 工具。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;当用户发送图片时，你需要仔细分析图片内容并回答用户的问题。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;【nanobot 路由规则 - 文档/文件交付 &amp;amp; Skills】当用户提出任何需要“生成/编辑/读取/转换并保存到本地”的交付物请求时（尤其是 docx/pdf/pptx/xlsx，或截图/本地 Web 应用交互测试 webapp-testing），无论用户是否明确说“用 nanobot_router 工具”，你都必须调用且只调用一次 nanobot_router，把用户原话作为 message 传入（必要时可补充你理解到的关键约束，如字数、格式、保存到本地、需要返回路径）。不要要求用户使用特定触发词。调用后工具会立即返回“任务已提交…”，最终结果会稍后自动出现在对话中；你无需再额外解释或重复调用工具。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;【nanobot 与简单问候】若用户只是发送简单问候（如「你好」「在吗」），请正常回复问候，不要提及正在处理任务。&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;【Agent TARS 使用规则】当用户请求你在具体网站上执行复杂多步操作并整理结果（例如在 https://www.baidu.com/ 上检索信息并编写旅游指南），且本地简单工具（系统信息、URL 打开、搜索提示等）不足以完成时，你应该调用一次 agent_tars_router 工具，将用户指令全文作为 instruction 传入；简单问答或无需真实网页操作时不要调用该工具。&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; ],&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;VisionConfig&quot;: { &quot;Enable&quot;: true },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ThinkingType&quot;: &quot;disabled&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Prefill&quot;: true,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;HistoryLength&quot;: 10&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetASR&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Provider&quot;: &quot;volcano&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ProviderParams&quot;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Mode&quot;: &quot;bigmodel&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;AppId&quot;: &quot;9934702733&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;AccessToken&quot;: &quot;WIG86BTrlHUsfx5pZefYgkGXCwtb44mV&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ApiResourceId&quot;: &quot;volc.bigasr.sauc.duration&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetTTS&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;`{&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;Provider&quot;: &quot;volcano_bidirection&quot;,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ProviderParams&quot;: {&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;app&quot;: { &quot;appid&quot;: &quot;9934702733&quot;, &quot;token&quot;: &quot;WIG86BTrlHUsfx5pZefYgkGXCwtb44mV&quot; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;audio&quot;: { &quot;voice_type&quot;: &quot;zh_male_wennuanahu_moon_bigtts&quot; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;ResourceId&quot;: &quot;volc.service_type.10029&quot;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; },&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &quot;IgnoreBracketText&quot;: [1,2,3,4,5]&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&amp;nbsp; &amp;nbsp; }`&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;SetExtraConfig&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;InterruptMode&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;, &lt;/span&gt;&lt;span style=&quot;color: #e394dc;&quot;&gt;&quot;0&quot;&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableSubtitle&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(&lt;/span&gt;&lt;span style=&quot;color: #ebc88d;&quot;&gt;0&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableConversationStateCallback&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(true)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; .&lt;/span&gt;&lt;span style=&quot;color: #efb080;&quot;&gt;EnableDebug&lt;/span&gt;&lt;span style=&quot;color: #e4e4e4;&quot;&gt;(true);&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;" id="IPRdIbJHup9Mvk_TXT2r-3">
